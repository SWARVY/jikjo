{
  "name": "@jikjo/core",
  "version": "0.2.0",
  "type": "module",
  "description": "Headless Lexical editor core for jikjo",
  "keywords": [
    "lexical",
    "editor",
    "jikjo",
    "headless"
  ],
  "author": "SWARVY",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check-types": "tsc --noEmit"
  },
  "peerDependencies": {
    "@lexical/react": "^0.38.0",
    "@lexical/rich-text": "^0.38.2",
    "lexical": "^0.38.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@jikjo/typescript-config": "workspace:*",
    "@lexical/react": "^0.38.2",
    "@lexical/rich-text": "^0.38.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "lexical": "^0.38.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsdown": "^0.12.7",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@lexical/html": "^0.38.2",
    "@lexical/markdown": "^0.38.2"
  }
}
